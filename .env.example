# Frontend URL to reach the backend API service
# Local backend default: http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Supabase Auth (frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: allow admin access by email list in addition to role metadata
# Example: ADMIN_ALLOWED_EMAILS=admin@welearn.ma,owner@welearn.ma
ADMIN_ALLOWED_EMAILS=
